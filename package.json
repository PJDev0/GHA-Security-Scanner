{
  "name": "gha-security-scanner",
  "version": "1.0.0",
  "description": "Security scanner for GitHub Actions workflows",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "package": "ncc build lib/action/index.js -o dist --source-map --license licenses.txt",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf lib dist",
    "prepare": "npm run clean && npm run build && npm run package",
    "ci": "npm run lint && npm run test && npm run prepare"
  },
  "keywords": ["github-actions", "security", "scanner", "sarif", "sbom"],
  "license": "MIT",
  "dependencies": {
    "@actions/artifact": "^2.1.1",
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@octokit/auth-token": "^4.0.0",
    "@octokit/rest": "^20.0.2",
    "ajv": "^8.12.0",
    "chalk": "^5.3.0",
    "fast-glob": "^3.3.2",
    "ora": "^8.0.1",
    "table": "^6.8.1",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.4",
    "@types/yaml": "^1.9.7",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20"
  }
}
